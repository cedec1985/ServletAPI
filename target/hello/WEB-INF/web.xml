<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <display-name>hello</display-name>
    <servlet-mapping>
        <servlet-name>BarcodeUtil</servlet-name>
        <url-pattern>/BarcodeUtil</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>time.html</welcome-file>
    </welcome-file-list>
    <!-- la déclaration de la servlet -->
    <servlet>
        <servlet-name>Time</servlet-name>
        <!-- le nom de la classe implémentant la servlet (précédé du nom du package) -->
        <servlet-class>servlet.Time</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Barcode</servlet-name>
        <servlet-class>org.krysalis.barcode4j.servlet.BarcodeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>QRCode</servlet-name>
        <servlet-class>org.krysalis.barcode4j.servlet.BarcodeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PdfExportServlet</servlet-name>
        <servlet-class>servlet.PdfExportServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>BarcodeUtil</servlet-name>
        <servlet-class>servlet.BarcodeUtil</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Time</servlet-name>
        <!-- le motif d'url (par exemple *.html ou /servlet) -->
        <url-pattern>/Time</url-pattern>
    </servlet-mapping>
    <!-- l'association de la servlet avec un motif d'URL -->
    <servlet-mapping>
        <servlet-name>Barcode</servlet-name>
        <url-pattern>/Barcode</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>QRCode</servlet-name>
        <url-pattern>/QRCode</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PdfExportServlet</servlet-name>
        <url-pattern>/PdfExportServlet</url-pattern>
    </servlet-mapping>
</web-app>
